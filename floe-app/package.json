{
  "name": "floe-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 5379",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1 --port 5379",
    "test": "vitest run",
    "test:unit": "vitest run",
    "typecheck": "tsc --noEmit",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:attach": "tauri dev --config src-tauri/tauri.attach.conf.json",
    "tauri:build": "tauri build"
  },
  "dependencies": {
    "floe-ext-snowball": "*",
    "@tauri-apps/api": "^2.11.0",
    "@vitejs/plugin-react": "^6.0.2",
    "@xyflow/react": "^12.10.2",
    "lucide-react": "^0.468.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "typescript": "^5.9.0",
    "vite": "^8.0.10",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "jsdom": "^29.1.1",
    "vitest": "^4.1.6"
  }
